{
  "name": "hallo-wereld",
  "displayName": "Hallo-Wereld",
  "description": "setup for a programming language",
  "publisher": "Hallo-Wereld",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "url": "https://github.com/renzos2007/Hallo-Wereld-vs-extension.git",
    "type": "github"
  },
  "icon": "logo.ico",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hallo-wereld.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "hallo-wereld.halloWereldPython",
        "title": "Hallo Wereld Python"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@vscode/vsce": "^3.9.2"
  }
}
